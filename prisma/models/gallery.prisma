/// 갤러리
model Gallery {
  id           Int       @id @default(autoincrement())
  title        String
  content      String
  imageUrl     String?
  videoUrl     String?
  keywords     String[]  @default([])
  eventName    String?
  shootingDate String?
  isExposed    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
}
